{
  "name": "ephr-in",
  "description": "EPHR Website",
  "author": "Ahmed Essam",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmadessamdev/EPHR-In-site.git"
  },
  "bugs": {
    "url": "https://bitbucket.org/pasqualevitiello/solid/issues"
  },
  "scripts": {
    "clean": "rimraf dist/{css/*,js/*,images/*}",
    "autoprefixer": "postcss src/scss/style.css -u autoprefixer -o dist/css/style.css",
    "scss": "sass -s compressed dist/css src/scss",
    "lint": "eslint src/js || true",
    "lint-scss": "stylelint src/scss/*.scss scss || true",
    "uglify": "mkdirp dist/js -p && uglifyjs src/js/*.js -m -c -o dist/js/main.min.js",
    "imagemin": "imagemin src/images/* -o dist/images",
    "serve": "browser-sync start --server --files \"dist/css/*.css, dist/js/*.js, **/*.html, !node_modules/**/*.html\"",
    "build:css": "run-s lint-scss scss autoprefixer",
    "build:js": "run-s lint uglify",
    "build:images": "run-s imagemin",
    "build": "run-s build:*",
    "watch:css": "onchange \"src/scss\" -- run-s build:css",
    "watch:js": "onchange \"src/js\" -- run-s build:js",
    "watch:images": "onchange \"src/images\" -- run-s build:images",
    "watch": "run-p serve watch:*"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "browser-sync": "^2.12.8",
    "eslint": "^10.4.1",
    "imagemin-cli": "^6.0.0",
    "mkdirp": "^0.5.1",
    "npm-run-all": "^4.1.3",
    "onchange": "^7.1.0",
    "postcss-cli": "^11.0.1",
    "rimraf": "^2.5.4",
    "sass": "^1.100.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "uglify-es": "^3.3.10"
  },
  "homepage": "https://github.com/ahmadessamdev/EPHR-In-site",
  "main": ".eslintrc.js",
  "dependencies": {
    "14": "^1.0.1",
    "sass": "^1.100.0",
    "stylelint-scss": "^7.2.0"
  }
}
